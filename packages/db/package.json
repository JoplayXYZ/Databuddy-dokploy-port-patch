{
  "name": "@databuddy/db",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/drizzle/schema/index.ts",
    "./schema/relations": "./src/drizzle/schema/relations.ts",
    "./clickhouse": "./src/clickhouse/index.ts",
    "./clickhouse/schema": "./src/clickhouse/schema.ts",
    "./e2e-db-lifecycle": "./src/e2e-db-lifecycle.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:push": "dotenv -- drizzle-kit push",
    "db:studio": "dotenv -- drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "clickhouse:init": "tsx src/clickhouse/setup.ts",
    "test": "bun test src",
    "e2e:db:create": "bun ./scripts/e2e-db-lifecycle.ts create",
    "e2e:db:drop": "bun ./scripts/e2e-db-lifecycle.ts drop"
  },
  "dependencies": {
    "@clickhouse/client": "^1.14.0",
    "@databuddy/cache": "workspace:*",
    "@faker-js/faker": "^9.9.0",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "catalog:",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^1.0.0-rc.1",
    "tsx": "^4.21.0"
  }
}
