{
  "name": "@databuddy/slack",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development dotenv -e ../../.env -- bun --watch src/index.ts",
    "start": "dotenv -e ../../.env -- bun src/index.ts",
    "manifest:validate": "dotenv -e ../../.env -- bun scripts/update-manifest.ts --validate",
    "manifest:update": "dotenv -e ../../.env -- bun scripts/update-manifest.ts",
    "check-types": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@databuddy/db": "workspace:*",
    "@databuddy/encryption": "workspace:*",
    "@databuddy/env": "workspace:*",
    "@slack/bolt": "^4.7.2",
    "@slack/web-api": "^7.15.1"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
