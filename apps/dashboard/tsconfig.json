{
  "extends": "../../tsconfig/next.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@lib/*": ["./lib/*"],
      "~/*": ["../dashboard"]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next\\dev/types/**/*.ts",
    ".next\\dev/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    ".turbo",
    ".turbo",
    "**/node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
